# =====================================================
# 환경변수 설정 파일 예시
# 이 파일을 복사해서 .env 파일을 만들고 값을 채워주세요.
#   cp .env.example .env
#
# ⚠️ .env 파일은 절대 GitHub에 올리지 마세요!
#    (이미 .gitignore에 등록되어 있습니다)
# =====================================================

# Railway PostgreSQL 연결 문자열
# Railway 대시보드 → PostgreSQL 서비스 → Variables 탭에서 복사
DATABASE_URL=postgresql://유저명:비밀번호@호스트:포트/DB명

# 실행 환경 (로컬: development / 배포: production)
# Railway에서는 자동으로 production 으로 설정됩니다.
NODE_ENV=development

# 관리자 페이지 로그인 정보
# Railway 대시보드 → 웹 서비스 → Variables 탭에 아래 두 항목을 추가하세요.
# ⚠️ 실제 값은 여기에 쓰지 말고 Railway Variables에만 입력하세요.
ADMIN_ID=여기에_아이디_입력
ADMIN_PW=여기에_비밀번호_입력

# 감사 이메일 발송 설정 (범용 SMTP)
#
# 자체 도메인 메일 (예: info@yourdomain.com)
#   SMTP_HOST=mail.yourdomain.com  (호스팅 업체 제공값)
#   SMTP_PORT=587                  (일반적으로 587 또는 465)
#   SMTP_USER=info@yourdomain.com
#   SMTP_PASS=메일_비밀번호
#
# Gmail 사용 시
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=앱_비밀번호_16자리  (Google 계정 → 보안 → 앱 비밀번호)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=발신자_이메일주소
SMTP_PASS=메일_비밀번호

# 서비스 URL (이메일 내 다운로드 링크 base URL)
# 로컬: http://localhost:3000 / 배포: https://your-app.railway.app
SITE_URL=http://localhost:3000
